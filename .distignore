# Files EXCLUDED from the distributable plugin zip built by `wp dist-archive`.
#
# dist-archive reads ONLY this file — never .gitignore — so build/ (gitignored,
# regenerated by `npm run build` before packaging) and languages/ are NOT listed
# here and therefore ship. The zip keeps: consentful.php, uninstall.php,
# readme.txt, src/ (PHP runtime), build/, languages/, and vendor/ (the Composer
# PSR-4 autoloader, built --no-dev before packaging).

# Version control / CI
.git
.gitignore
.gitattributes
.github
/.wp-env.json
/RELEASE_BODY.md

# OS / editor cruft
.DS_Store
.idea
.vscode
*.swp
*.log

# Local assistant / skill state
/.fallow
/.impeccable

# Node toolchain — never shipped. vendor/ is intentionally NOT excluded: the
# production Composer autoloader (built --no-dev) ships so PSR-4 classes resolve.
node_modules

# Front-end source — compiled into build/ at release time (build/ itself ships).
# Anchored: dist-archive v3 uses gitignore any-depth matching, so a bare
# `assets` would also exclude build/assets/ (the hashed gate bundle the
# manifest names).
/assets

# Tests
tests
phpunit.xml.dist
.phpunit.cache

# Developer docs (the shipped, user-facing readme is readme.txt)
/README.md
/CLAUDE.md
/CONTEXT.md
/PRODUCT.md
/docs

# Tooling / build / lint / static-analysis config
composer.json
composer.lock
package.json
package-lock.json
vite.config.js
/vite.config.decider.js
/vitest.config.js
eslint.config.js
.stylelintrc.json
.phpcs.xml.dist
.phpcs.xml
phpstan.neon.dist
phpstan.neon
phpstan-baseline.neon
.phpactor.json

# This file and any local packaging output
.distignore
*.zip
/dist
