# Files EXCLUDED from the distributable plugin zip built by `wp dist-archive`.
#
# dist-archive reads ONLY this file — never .gitignore — so build/ (gitignored,
# regenerated by `npm run build` before packaging) and languages/ are NOT listed
# here and therefore ship. The zip keeps exactly: consent-mode-v2.php,
# uninstall.php, readme.txt, build/, languages/.

# Version control / CI
.git
.gitignore
.gitattributes
.github

# OS / editor cruft
.DS_Store
.idea
.vscode
*.swp
*.log

# Dependencies (dev-only; vendor has no runtime autoload)
node_modules
vendor

# Source — compiled into build/ at release time (build/ itself ships)
src

# Developer readme (the shipped, user-facing readme is readme.txt)
/README.md

# Tooling / build / lint / static-analysis config
composer.json
composer.lock
package.json
package-lock.json
vite.config.js
eslint.config.js
.stylelintrc.json
.phpcs.xml.dist
.phpcs.xml
phpstan.neon.dist
phpstan.neon
phpstan-baseline.neon
.phpactor.json

# This file and any local packaging output
.distignore
*.zip
