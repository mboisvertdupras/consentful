# macOS
.DS_Store

# Editor / tooling
.idea/
.vscode/
.phpactor.json
*.swp

# Logs
*.log

# Dependencies
/node_modules/
/vendor/

# Build output (run `npm run build` to generate; produced at release time)
/build/
/dist/

# Generated i18n artifacts (run `npm run i18n`; .po files are the tracked source)
/languages/*.mo
/languages/consentful.pot

# Test cache
/.phpunit.cache/

# Local tool overrides
/phpstan.neon
/.phpcs.xml
.impeccable
