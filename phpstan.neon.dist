# PHPStan configuration — WordPress plugin.
# The szepeviktor/phpstan-wordpress extension loads the WordPress core stubs
# and teaches PHPStan about dynamic hooks, so analysis works without a full
# WordPress checkout. Level max with a baseline (aim: empty).
includes:
	- vendor/szepeviktor/phpstan-wordpress/extension.neon
	- phpstan-baseline.neon

parameters:
	level: max
	paths:
		- consentful.php
		- uninstall.php
		- src
		- tests/Unit
	excludePaths:
		- vendor/
		- node_modules/
		- build/
		- assets/
		- languages/
		- tests/bootstrap.php
		- tests/stubs.php
	# Treat the WordPress `Requires PHP` floor as the analysis target.
	phpVersion: 80100
